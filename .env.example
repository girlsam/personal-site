# Spotify "now playing / last played" widget (lib/spotify.ts).
# Copy this file to .env.local and fill in the values.
#
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add http://127.0.0.1:8888/callback as a Redirect URI
# 3. Fill CLIENT_ID/SECRET below, then run:
#      node --env-file=.env.local scripts/spotify-auth.mjs
#    to mint SPOTIFY_REFRESH_TOKEN.
#
# The widget hides itself until all three are set.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
